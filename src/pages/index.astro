import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>🧑‍🚀 Hello, There!</h1>
			<p>
				Welcome to the my blog starter template.
				This will be a place where I dump everything I learn about simulation.
			</p>
		</main>
		<Footer />
	</body>
</html>
